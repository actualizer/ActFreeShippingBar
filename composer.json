{
  "name": "actualizer/free-shipping-bar",
  "description": "Displays a free shipping progress bar in the cart and offcanvas cart.",
  "type": "shopware-platform-plugin",
  "license": "MIT",
  "version": "1.0.8",
  "authors": [
    {
      "name": "Actualize",
      "email": "plugin@actualize.de",
      "homepage": "https://actualize.de",
      "role": "Developer"
    }
  ],
  "scripts": {
    "format": "docker run --rm -v $(pwd):/ext shopware/shopware-cli:latest extension format /ext",
    "check": "docker run --rm -v $(pwd):/ext shopware/shopware-cli:latest extension validate --full /ext"
  },
  "autoload": {
    "psr-4": {
      "Act\\FreeShippingBar\\": "src/"
    }
  },
  "extra": {
    "shopware-plugin-class": "Act\\FreeShippingBar\\ActFreeShippingBar",
    "label": {
      "de-DE": "Actualize: Kostenloser Versand Fortschrittsbalken",
      "en-GB": "Actualize: Free Shipping Progress Bar"
    },
    "description": {
      "de-DE": "Zeigt im Warenkorb und Offcanvas-Warenkorb einen Fortschrittsbalken zum kostenlosen Versand an und berechnet die Versandkostenfrei-Schwelle automatisch aus den Versandarten.",
      "en-GB": "Displays a free-shipping progress bar in the cart and offcanvas cart and automatically derives the free-shipping threshold from the configured shipping method prices."
    },
    "manufacturerLink": {
      "de-DE": "https://actualize.de",
      "en-GB": "https://actualize.de"
    },
    "supportLink": {
      "de-DE": "https://github.com/actualizer/ActFreeShippingBar/issues",
      "en-GB": "https://github.com/actualizer/ActFreeShippingBar/issues"
    }
  },
  "require": {
    "php": ">=8.4",
    "shopware/core": ">=6.7 <6.8",
    "shopware/storefront": ">=6.7 <6.8"
  }
}
