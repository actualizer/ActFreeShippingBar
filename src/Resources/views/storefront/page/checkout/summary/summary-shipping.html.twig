{% sw_extends '@Storefront/storefront/page/checkout/summary/summary-shipping.html.twig' %}

{% block page_checkout_summary_shippings %}
    {{ parent() }}

    {% if page.extensions.actFreeShippingBar is defined %}
        {% set fsb = page.extensions.actFreeShippingBar %}

        {% if fsb.freeShippingPossible %}
            {% if fsb.reached and fsb.showWhenReached %}
                <dd class="col-12">
                    <div class="act-free-shipping-bar act-free-shipping-bar--reached mt-1">
                        <div class="act-free-shipping-bar__message text-success fw-bold small">
                            {{ 'actFreeShippingBar.reached'|trans|sw_sanitize }}
                        </div>
                        {% if fsb.showProgressBar %}
                            <div class="progress mt-1" style="height: 6px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        {% endif %}
                    </div>
                </dd>
            {% elseif not fsb.reached %}
                <dd class="col-12">
                    <div class="act-free-shipping-bar mt-1">
                        <div class="act-free-shipping-bar__message small">
                            {{ 'actFreeShippingBar.remaining'|trans({'%amount%': fsb.remaining|currency})|sw_sanitize }}
                        </div>
                        {% if fsb.showProgressBar %}
                            <div class="progress mt-1" style="height: 6px;">
                                <div class="progress-bar" role="progressbar" style="width: {{ fsb.percentage }}%" aria-valuenow="{{ fsb.percentage|round }}" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        {% endif %}
                    </div>
                </dd>
            {% endif %}
        {% endif %}
    {% endif %}
{% endblock %}
